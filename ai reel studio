'use client';
import { useState, useEffect } from 'react';
import { format } from 'date-fns';

interface Reel {
  id: string;
  date: string;
  trend: string;
  caption: string;
  videoPrompt: string;
  niche: string;
}

export default function TrendReelPro() {
  const [handle, setHandle] = useState('@yourbrand');
  const [groqKey, setGroqKey] = useState('');
  const [niche, setNiche] = useState('Travel');
  const [trends, setTrends] = useState<string[]>([]);
  const [isLoading, setIsLoading] = useState(false);
  const [logs, setLogs] = useState<string[]>([]);
  const [history, setHistory] = useState<Reel[]>([]);
  const [activeTab, setActiveTab] = useState(0);
  const [currentReel, setCurrentReel] = useState<Reel | null>(null);

  const niches = ['Travel', 'Fitness', 'Food', 'Tech', 'Finance'];

  const addLog = (msg: string) => {
    setLogs(prev => [`[${format(new Date(), 'HH:mm:ss')}] ${msg}`, ...prev.slice(0, 12)]);
  };

  useEffect(() => {
    const savedHandle = localStorage.getItem('reelHandle');
    const savedKey = localStorage.getItem('groqKey');
    const savedHistory = localStorage.getItem('reelHistory');
    
    if (savedHandle) setHandle(savedHandle);
    if (savedKey) setGroqKey(savedKey);
    if (savedHistory) setHistory(JSON.parse(savedHistory));
    
    fetchTrends();
  }, []);

  const fetchTrends = async () => {
    setIsLoading(true);
    addLog(`Fetching trends for ${niche}...`);
    
    const fallbackTrends: Record<string, string[]> = {
      Travel: ["Solo travel transformation", "Hidden gems Europe 2026", "Digital nomad lifestyle"],
      Fitness: ["Morning routine 2026", "Home workout no equipment", "Mobility drills"],
      Food: ["5 ingredient meals", "High protein breakfast", "Airfryer recipes"],
      Tech: ["Grok 4 updates", "New AI agents", "No-code tools 2026"],
      Finance: ["Side hustle ideas", "Passive income 2026", "Credit card hacks"]
    };

    setTrends(fallbackTrends[niche as keyof typeof fallbackTrends] || fallbackTrends.Travel);
    addLog(`✅ Loaded trending topics`);
    setIsLoading(false);
  };

  const generateReel = async (selectedTrend?: string) => {
    if (!groqKey) return addLog("❌ Please enter your Groq API key");

    setIsLoading(true);
    const trend = selectedTrend || trends[0] || "viral hack";

    addLog(`Generating reel for: ${trend}`);

    try {
      const res = await fetch('/api/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ trend, niche, groqKey })
      });

      const data = await res.json();

      const newReel: Reel = {
        id: Date.now().toString(),
        date: new Date().toISOString(),
        trend,
        caption: data.caption,
        videoPrompt: data.videoPrompt,
        niche
      };

      setCurrentReel(newReel);
      const updated = [newReel, ...history];
      setHistory(updated);
      localStorage.setItem('reelHistory', JSON.stringify(updated));

      addLog("✅ Caption generated successfully");
      addLog("🎬 Video prompt for Kling/Runway ready");
    } catch (err) {
      addLog("❌ Error generating reel");
    }
    setIsLoading(false);
  };

  const saveHandle = () => {
    localStorage.setItem('reelHandle', handle);
    addLog(`📸 Handle saved: ${handle}`);
  };

  const saveGroqKey = () => {
    localStorage.setItem('groqKey', groqKey);
    addLog("🔑 Groq API key saved");
  };

  return (
    <div className="flex h-screen bg-zinc-950">
      {/* Sidebar */}
      <div className="w-80 bg-zinc-900 border-r border-zinc-800 p-6 flex flex-col">
        <div className="flex items-center gap-3 mb-10">
          <div className="text-4xl">📈</div>
          <h1 className="logo-font text-4xl font-bold tracking-tighter">TrendReel</h1>
        </div>

        <div className="space-y-6">
          <div>
            <label className="text-xs text-zinc-400 block mb-2">Instagram Handle</label>
            <div className="flex gap-2">
              <input value={handle} onChange={(e) => setHandle(e.target.value)} className="flex-1 bg-zinc-800 rounded-2xl px-4 py-3 text-sm" />
              <button onClick={saveHandle} className="bg-violet-600 px-6 rounded-2xl text-sm font-medium">Save</button>
            </div>
          </div>

          <div>
            <label className="text-xs text-zinc-400 block mb-2">Groq API Key</label>
            <input type="password" value={groqKey} onChange={(e) => setGroqKey(e.target.value)} className="w-full bg-zinc-800 rounded-2xl px-4 py-3 text-sm" placeholder="gsk_..." />
            <button onClick={saveGroqKey} className="text-xs text-violet-400 mt-2">Save Key</button>
          </div>

          <div>
            <label className="text-xs text-zinc-400 block mb-2">Niche</label>
            <select value={niche} onChange={(e) => setNiche(e.target.value)} className="w-full bg-zinc-800 rounded-2xl px-4 py-3">
              {niches.map(n => <option key={n} value={n}>{n}</option>)}
            </select>
          </div>

          <button onClick={fetchTrends} className="w-full py-3 bg-zinc-800 hover:bg-zinc-700 rounded-2xl font-medium">Fetch Live Trends</button>
          <button onClick={() => generateReel()} disabled={isLoading} className="w-full py-4 bg-white text-black rounded-2xl font-semibold text-lg hover:bg-amber-100">
            {isLoading ? "Generating..." : "Generate Reel Now"}
          </button>
        </div>
      </div>

      {/* Main Area */}
      <div className="flex-1 flex flex-col">
        <div className="h-16 border-b border-zinc-800 flex items-center px-8 gap-8">
          {['Trends', 'Generate', 'Batch', 'History'].map((tab, i) => (
            <button key={i} onClick={() => setActiveTab(i)} className={`pb-1 ${activeTab === i ? 'border-b-2 border-violet-500 font-semibold' : 'text-zinc-400'}`}>
              {tab}
            </button>
          ))}
        </div>

        <div className="flex-1 p-8 overflow-auto">
          {activeTab === 0 && (
            <div className="grid grid-cols-3 gap-4">
              {trends.map(trend => (
                <div key={trend} onClick={() => generateReel(trend)} className="bg-zinc-900 p-6 rounded-3xl hover:bg-zinc-800 cursor-pointer transition-all">
                  <p className="font-medium">{trend}</p>
                </div>
              ))}
            </div>
          ))}

          {activeTab === 1 && currentReel && (
            <div className="max-w-3xl mx-auto bg-zinc-900 rounded-3xl p-10 space-y-8">
              <h3 className="text-emerald-400 text-2xl font-semibold">Reel Generated Successfully</h3>
              <div>
                <p className="text-xs uppercase tracking-widest text-zinc-400 mb-2">Caption</p>
                <p className="text-lg leading-relaxed">{currentReel.caption}</p>
              </div>
              <div>
                <p className="text-xs uppercase tracking-widest text-zinc-400 mb-2">Video Prompt (Kling / Runway)</p>
                <div className="bg-black p-6 rounded-2xl text-sm font-light whitespace-pre-wrap leading-relaxed">
                  {currentReel.videoPrompt}
                </div>
              </div>
            </div>
          ))}

          {activeTab === 2 && (
            <div>
              <h2 className="text-3xl font-bold mb-6">Multi-Day Batch Generation</h2>
              <div className="flex gap-4">
                {[3, 5, 7].map(days => (
                  <button key={days} onClick={() => { for (let i = 0; i < days; i++) generateReel(); }} 
                          className="px-12 py-8 bg-zinc-800 hover:bg-zinc-700 rounded-3xl text-lg font-medium">
                    {days} Days
                  </button>
                ))}
              </div>
            </div>
          ))}

          {activeTab === 3 && (
            <div>
              <h2 className="text-2xl font-bold mb-6">Generation History</h2>
              {history.length === 0 ? <p>No reels yet.</p> : history.map(reel => (
                <div key={reel.id} className="bg-zinc-900 p-5 rounded-2xl mb-4">
                  <p className="text-sm text-zinc-400">{new Date(reel.date).toLocaleDateString()}</p>
                  <p className="font-medium">{reel.trend}</p>
                  <p className="text-sm text-zinc-400 line-clamp-2 mt-2">{reel.caption}</p>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Log Panel */}
        <div className="h-72 bg-black border-t border-zinc-800 p-6 font-mono text-xs overflow-auto space-y-1">
          {logs.map((log, i) => <div key={i}>{log}</div>)}
        </div>
      </div>
    </div>
  );
}
import { NextRequest } from 'next/server';
import { Groq } from 'groq-sdk';

export async function POST(req: NextRequest) {
  const { trend, niche, groqKey } = await req.json();

  const groq = new Groq({ apiKey: groqKey });

  const completion = await groq.chat.completions.create({
    model: "llama-3.3-70b-versatile",
    messages: [{
      role: "user",
      content: `Write a highly engaging Instagram Reel caption about "${trend}" in ${niche} niche. Max 140 characters. Use emojis and strong CTA.`
    }],
    temperature: 0.85,
    max_tokens: 180
  });

  const caption = completion.choices[0]?.message?.content || "This is going viral right now 🔥 Tag someone!";

  const videoPrompt = `Cinematic 9:16 vertical video. Subject: ${trend} in ${niche}. Fast cuts every 0.7 seconds, vibrant colors, dynamic camera movement, bold animated text overlays synced to music beat drop. High energy, trending on Instagram Reels.`;

  return Response.json({ caption, videoPrompt });
}
